function isPalindrome (string){
    let left = 0, right = string.length - 1

    while (left < right){
        if (string[left] != string[right]){
            return false
        } else {
            left++
            right--
        }
    }
    return true
}

function main(){
    const string = "racecar"
    console.log(isPalindrome(string))
    console.log(isPalindrome("hello"))
    console.log(isPalindrome("abba"))
}

main()